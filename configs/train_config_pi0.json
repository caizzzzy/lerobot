{
  "dataset": {
    "repo_id": "lerobot_dataset_0405_pi0",
    "root": "data/lerobot_dataset_0405_pi0",
    "episodes": null,
    "local_files_only": false,
    "use_imagenet_stats": false,
    "video_backend": "pyav"
  },

  "env": null,

  "policy": {
    "type": "pi0",
    "repo_id": "lerobot_dataset_0405_pi0",
    "push_to_hub": false,
    "pretrained_path": "lerobot/pi0_base",
    "device": "cuda",
    "dtype": "bfloat16",
    "use_amp": false,
    "n_obs_steps": 1,
    "chunk_size": 50,
    "n_action_steps": 50,
    "gradient_checkpointing": true,
    "compile_model": false,
    "freeze_vision_encoder": false,
    "train_expert_only": true,
    "normalization_mapping": {
      "VISUAL": "IDENTITY",
      "STATE": "MEAN_STD",
      "ACTION": "MEAN_STD"
    },
    "input_features": {
      "observation.images.cam_high": {
        "type": "VISUAL",
        "shape": [
          3,
          480,
          640
        ]
      },
      "observation.images.cam_global": {
        "type": "VISUAL",
        "shape": [
          3,
          480,
          640
        ]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [
          8
        ]
      }
    },
    "output_features": {
      "action": {
        "type": "ACTION",
        "shape": [
          8
        ]
      }
    },
    "optimizer_lr": 2.5e-5,
    "optimizer_betas": [
      0.9,
      0.95
    ],
    "optimizer_eps": 1e-8,
    "optimizer_weight_decay": 0.01,
    "optimizer_grad_clip_norm": 1.0,
    "scheduler_warmup_steps": 1000,
    "scheduler_decay_steps": 30000,
    "scheduler_decay_lr": 2.5e-6
  },

  "output_dir": "outputs/train/lerobot_dataset_0405_pi0",
  "job_name": "lerobot_dataset_0405_pi0",
  "resume": false,
  "seed": 1000,
  "num_workers": 4,
  "batch_size": 4,
  "steps": 3000,
  "eval_freq": 5000,
  "log_freq": 50,
  "save_checkpoint": true,
  "save_freq": 5000,
  "use_policy_training_preset": true,

  "wandb": {
    "enable": true,
    "disable_artifact": true,
    "project": "lerobot",
    "entity": "1259809511-south-china-university-of-technology",
    "notes": "pi0 finetune on lerobot_dataset_0405_pi0 with cam_high + cam_global",
    "mode": "online"
  }
}
